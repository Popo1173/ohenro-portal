{% macro formInput(label, id, placeholder="Your Email", type="email") %}
<div class="form-group">
  <label for="{{ id }}" class="form-label">{{ label }}</label>
  <input 
    type="{{ type }}" 
    id="{{ id }}" 
    name="{{ id }}" 
    placeholder="{{ placeholder }}" 
    class="form-input"
  >
</div>
{% endmacro %}