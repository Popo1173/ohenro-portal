{% macro passwordField(label, id, placeholder="Password") %}
<div class="password-field js-password-container">
  <label for="{{ id }}" class="password-field__label">{{ label }}</label>
  <div class="password-field__inner">
    <input 
      type="password" 
      id="{{ id }}" 
      name="{{ id }}" 
      placeholder="{{ placeholder }}" 
      class="password-field__input js-password-input"
    >
    <button type="button" class="password-field__switch js-password-toggle" aria-label="パスワードを表示する">
      {# 目のアイコン（SVG） #}
      <svg class="icon-eye" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
        <circle cx="12" cy="12" r="3"></circle>
      </svg>
    </button>
  </div>
</div>
{% endmacro %}