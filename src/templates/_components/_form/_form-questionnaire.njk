{% macro selectField(q, name) %}
<div class="questionnaire-field js-q"
	data-q="{{ name }}"
	{% if q.showIf %}data-show-if="{{ q.showIf }}"{% endif %}>

  <label class="questionnaire-field__label" for="{{ name }}">{{ q.label }}</label>
  {% if q.options %}
    <select class="questionnaire-field__select js-select" id="{{ name }}" name="{{ name }}" data-q="{{ name }}">
      <option value="">{{ q.placeholder }}</option>
      {% for opt in q.options %}
        <option value="{{ opt.value }}">{{ opt.label }}</option>
      {% endfor %}

      {% if q.other %}
        <option value="other">{{ q.other }}</option>
      {% endif %}
    </select>

    {% if q.other %}
		<input class="questionnaire-field__other js-other"
        type="text"
        name="{{ name }}_other"
        data-other-for="{{ name }}"
        placeholder="{{ q.otherPlaceholder }}"
        hidden>
    {% endif %}
  {% endif %}
</div>
{% endmacro %}

<!-- その他選択時のテキストボックス -->
{% macro textareaField(q, name) %}
<div class="questionnaire-field js-q" data-q="{{ name }}">
  <label class="questionnaire-field__label" for="{{ name }}">{{ q.label }}</label>
  <textarea class="questionnaire-field__textarea" id="{{ name }}" name="{{ name }}" type="text" rows="4"></textarea>
</div>
{% endmacro %}