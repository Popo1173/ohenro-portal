{% macro breadcrumbs(items, lang) %}
<nav class="breadcrumbs">
  <a href="/{{ lang }}/">HOME</a>

  {% for item in items %}
    <span> &gt; </span>

    {% if item.url %}
      <a href="/{{ lang }}{{ item.url }}/">{{ item.label }}</a>
    {% else %}
      <span>{{ item.label }}</span>
    {% endif %}
  {% endfor %}
</nav>
{% endmacro %}