{% from "_components/_lang-switcher.njk" import LangSwitcher %}
{% from "_components/_button-small.njk" import buttonPill %}
<div class="nav-desktop__controls">
  <ul class="nav-desktop__controls-list">
    <li class="nav-desktop__controls-item">{{ LangSwitcher(lang, locate[lang], page.url | replace('/' + lang, '')) }}</li>
    <li class="nav-desktop__controls-item">
      <a class="nav-desktop__controls-link" href="/{{ lang }}/logout/">
          <img src="/assets/images/icons/icon-logout.svg" alt="logout" />{{ t.headerUser.auth}}
      </a>
    </li>
  </ul>
</div>
<!-- ナビ -->
{% set navItems = [
  { link: "/" + lang + "/my-page/", label: t.headerUser.home, icon: "/assets/images/icons/icon-home.svg" },
  { link: "/" + lang + "/favorite/", label: t.headerUser.favorite, icon: "/assets/images/icons/icon-favorite.svg" },
  { link: "/" + lang + "/history/", label: t.headerUser.history, icon: "/assets/images/icons/icon-history.svg" }
] %}
<ul class="nav-desktop__nav-list">
  {% for item in navItems %}
  <li class="nav-desktop__nav-item">
    <a class="nav-desktop__nav-link" href="{{ item.link }}">
      <img src="{{ item.icon }}" alt="{{ item.label }}" />{{ item.label }}
    </a>
  </li>
  {% endfor %}
</ul>