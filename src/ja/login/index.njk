---
lang: ja
layout: _layout/_base.njk
headerType: auth
title: ログイン
description: ログイン
url: https://ohenro.online/ja/login/
---

<section class="login">
  <div class="login__inner">
    <div class="login__title">
      <h2 class="login__title-text">Sign Up</h2>
    </div>

    {% import "_components/_form/_form-field-text.njk" as forms %}
    {% import "_components/_form/_form-field-password.njk" as passForms %}
    {% import "_components/_button-big.njk" as buttons %}
    <form class="login__form">
      {# メールアドレス #}
      {{ forms.formInput("メールアドレス", "user-email", "Your Email") }}
      
      {# パスワード #}
      {{ passForms.passwordField("パスワード", "password", "Password") }}
      <p class="login__forget">
        <a class="login__forget-link" href="">パスワードを忘れた場合</a>
      </p>

      <div class="login__button">
        {{ buttons.primaryButton("ログイン", "submit", "/my-page/") }}
      </div>
    </form>
  </div>
</section>
